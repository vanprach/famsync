# FamSync Environment Variables Example

# =========================================================================
# 1. FRONTEND: Google Auth Client ID
# Get this from: https://console.cloud.google.com/apis/credentials
# Create a Web OAuth client ID, set redirect and origin to your website domains.
# =========================================================================
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# =========================================================================
# 2. BACKEND: Vercel KV and Blob connection credentials
# (NOTE: When deploying to Vercel, these keys are auto-injected in 1 click
# when you add KV and Blob integrations to the project. You don't need to
# copy-paste them manually. But if you want to connect to your live database
# from localhost, you can copy them from your Vercel Dashboard -> Storage Tab).
# =========================================================================
KV_URL=redis://default:xxxx@xxxx.upstash.io:30000
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxx
KV_REST_API_READ_ONLY_TOKEN=xxxx
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx
